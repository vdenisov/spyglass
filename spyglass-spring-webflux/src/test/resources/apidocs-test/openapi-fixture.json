{
  "openapi": "3.1.0",
  "info": {
    "title": "Fixture Explorer API",
    "version": "1.0.0"
  },
  "paths": {
    "/widgets/{id}": {
      "get": {
        "tags": ["Widgets"],
        "summary": "Get a widget by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "A widget",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
