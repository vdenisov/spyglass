<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.plukh.spyglass</groupId>
        <artifactId>spyglass-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>spyglass-core</artifactId>

    <name>Spyglass Core</name>
    <description>
        The framework-neutral front end: the no-build Vue/ESM application, the pre-built CodeMirror
        editor bundle, and config.js — served from META-INF/resources/apidocs/ by any Spring web stack
        on classpath presence alone. Static assets only: no Java, no server code, no framework
        dependency. The one build that exists (the CodeMirror bundle, under frontend/) runs only when
        the editor dependencies change; its output is committed.
    </description>

    <build>
        <plugins>
            <!--
                Ship the licence and the complete third-party notices inside the jar (under META-INF/)
                so the published artifact is self-attributing. THIRD-PARTY-NOTICES.txt is generated by
                frontend/build.mjs (Vue + marked + the CodeMirror bundle); LICENSE is the repo-root MIT.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>${maven-resources-plugin.version}</version>
                <executions>
                    <execution>
                        <id>copy-legal</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.outputDirectory}/META-INF</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${project.basedir}/..</directory>
                                    <includes>
                                        <include>LICENSE</include>
                                    </includes>
                                </resource>
                                <resource>
                                    <directory>${project.basedir}/frontend</directory>
                                    <includes>
                                        <include>THIRD-PARTY-NOTICES.txt</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!--
            Release-only. spyglass-core has no Java sources, so maven-javadoc/maven-source produce
            nothing and a Maven Central deploy would be rejected for the missing -javadoc/-sources jars.
            Skip those (no-op here anyway) and attach compliant placeholder jars instead — each carries a
            short README pointing at the real content (the assets in the main jar). Scoped to -Prelease,
            so normal builds are unaffected; the parent gpg/central plugins then sign and upload them.
        -->
        <profile>
            <id>release</id>
            <properties>
                <maven.source.skip>true</maven.source.skip>
                <maven.javadoc.skip>true</maven.javadoc.skip>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-jar-plugin</artifactId>
                        <executions>
                            <execution>
                                <id>placeholder-javadoc-jar</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                                <configuration>
                                    <classifier>javadoc</classifier>
                                    <classesDirectory>${project.basedir}/src/release/javadoc</classesDirectory>
                                    <forceCreation>true</forceCreation>
                                </configuration>
                            </execution>
                            <execution>
                                <id>placeholder-sources-jar</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                                <configuration>
                                    <classifier>sources</classifier>
                                    <classesDirectory>${project.basedir}/src/release/sources</classesDirectory>
                                    <forceCreation>true</forceCreation>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>
